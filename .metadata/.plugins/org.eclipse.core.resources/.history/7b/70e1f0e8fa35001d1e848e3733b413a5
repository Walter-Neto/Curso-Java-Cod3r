package Fundamentos;

public class TipoString {
	
	public static void main(String[] args) {
		
		System.out.println("Olá Pessoal.".charAt(5));
		
		String s = "Walter";
		System.out.println(s.concat("!!!"));
		System.out.println(s + "???");
		System.out.println(s.startsWith("Wal"));
		System.out.println(s.toLowerCase().startsWith("wal"));
		System.out.println(s.length());
		System.out.println(s.equals("walter"));
		System.out.println(s.equalsIgnoreCase("walter"));
		
		
	}

}
